// @ts-check

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTH
// ============================================

enum UserStatus {
  ACTIVE
  BANNED
  DELETED
}

model User {
  id               String     @id @default(uuid())
  
  // Telegram auth
  telegramUserId   BigInt?    @unique @map("telegram_user_id")
  telegramUsername String?    @map("telegram_username")
  phone            String?    
  
  // Admin auth
  username         String?    @unique
  password         String?    // bcrypt hashed
  isAdmin          Boolean    @default(false) @map("is_admin")
  
  displayName      String     @map("display_name")
  avatarUrl        String?    @map("avatar_url")
  isVerified       Boolean    @default(false) @map("is_verified")
  status           UserStatus @default(ACTIVE)
  
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")
  lastLoginAt      DateTime?  @map("last_login_at")

  // Relations
  listings         HorseListing[]
  favorites        Favorite[]
  viewLogs         ViewLog[]
  auditLogs        AuditLog[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("refresh_tokens")
}

// ============================================
// LOCATION
// ============================================

model Region {
  id       String     @id @default(uuid())
  nameUz   String     @map("name_uz")
  nameRu   String?    @map("name_ru")
  slug     String     @unique
  
  districts District[]
  listings  HorseListing[]
  events    Event[]

  @@map("regions")
}

model District {
  id       String  @id @default(uuid())
  regionId String  @map("region_id")
  nameUz   String  @map("name_uz")
  nameRu   String? @map("name_ru")
  slug     String  @unique

  region   Region  @relation(fields: [regionId], references: [id], onDelete: Cascade)
  listings HorseListing[]
  events   Event[]

  @@index([regionId])
  @@map("districts")
}

// ============================================
// HORSE LISTINGS
// ============================================

model Breed {
  id          String  @id @default(uuid())
  name        String  @unique
  slug        String  @unique
  description String?
  isActive    Boolean @default(true) @map("is_active")

  listings    HorseListing[]

  @@map("breeds")
}

enum HorsePurpose {
  KOPKARI
  SPORT
  SAYR
  ISHCHI
  NASLCHILIK
}

enum HorseGender {
  AYGIR
  BIYA
  AXTa
}

enum ListingStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  ARCHIVED
}

enum Currency {
  UZS
  USD
}

model HorseListing {
  id            String        @id @default(uuid())
  userId        String        @map("user_id")
  title         String
  slug          String        @unique
  description   String?
  
  regionId      String        @map("region_id")
  districtId    String?       @map("district_id")
  
  purpose       HorsePurpose?
  gender        HorseGender?
  breedId       String?       @map("breed_id")
  ageYears      Int?          @map("age_years")
  color         String?
  
  priceAmount   Decimal       @map("price_amount") @db.Decimal(15, 2)
  priceCurrency Currency      @default(UZS) @map("price_currency")
  
  hasPassport   Boolean       @default(false) @map("has_passport")
  hasVaccine    Boolean?      @map("has_vaccine")
  hasVideo      Boolean       @default(false) @map("has_video")
  
  status        ListingStatus @default(DRAFT)
  rejectReason  String?       @map("reject_reason")
  
  viewCount     Int           @default(0) @map("view_count")
  favoriteCount Int           @default(0) @map("favorite_count")
  
  publishedAt   DateTime?     @map("published_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  // Relations
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  region        Region        @relation(fields: [regionId], references: [id])
  district      District?     @relation(fields: [districtId], references: [id])
  breed         Breed?        @relation(fields: [breedId], references: [id])
  media         HorseMedia[]
  favorites     Favorite[]
  viewLogs      ViewLog[]

  @@index([userId])
  @@index([regionId])
  @@index([status])
  @@index([publishedAt])
  @@map("horse_listings")
}

enum MediaType {
  IMAGE
  VIDEO
}

model HorseMedia {
  id        String    @id @default(uuid())
  listingId String    @map("listing_id")
  type      MediaType @default(IMAGE)
  url       String
  thumbUrl  String?   @map("thumb_url")
  sortOrder Int       @default(0) @map("sort_order")
  createdAt DateTime  @default(now()) @map("created_at")

  listing   HorseListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@map("horse_media")
}

// ============================================
// USER INTERACTIONS
// ============================================

model Favorite {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  listingId String   @map("listing_id")
  createdAt DateTime @default(now()) @map("created_at")

  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   HorseListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId])
  @@map("favorites")
}

model ViewLog {
  id            String   @id @default(uuid())
  listingId     String   @map("listing_id")
  userId        String?  @map("user_id")
  sessionId     String?  @map("session_id")
  createdAt     DateTime @default(now()) @map("created_at")

  listing       HorseListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user          User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([listingId])
  @@index([userId])
  @@map("view_logs")
}

// ============================================
// EVENTS (KOPKARI)
// ============================================

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

model Event {
  id              String      @id @default(uuid())
  title           String
  slug            String      @unique
  description     String?     @db.Text
  
  regionId        String      @map("region_id")
  districtId      String?     @map("district_id")
  addressText     String?     @map("address_text")
  mapUrl          String?     @map("map_url")
  
  startsAt        DateTime    @map("starts_at")
  endsAt          DateTime?   @map("ends_at")
  
  organizerName   String      @map("organizer_name")
  contactPhone    String?     @map("contact_phone")
  contactTelegram String?     @map("contact_telegram")
  
  prizePool       Decimal?    @map("prize_pool") @db.Decimal(15, 2)
  prizeCurrency   Currency    @default(UZS) @map("prize_currency")
  rules           String?     @db.Text
  
  status          EventStatus @default(DRAFT)
  viewCount       Int         @default(0) @map("view_count")
  
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  publishedAt     DateTime?   @map("published_at")

  // Relations
  region          Region      @relation(fields: [regionId], references: [id])
  district        District?   @relation(fields: [districtId], references: [id])

  @@index([regionId])
  @@index([status])
  @@index([startsAt])
  @@map("events")
}

// ============================================
// BLOG
// ============================================

enum BlogPostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model BlogPost {
  id            String         @id @default(uuid())
  title         String
  slug          String         @unique
  excerpt       String?
  content       String         @db.Text
  coverImage    String?        @map("cover_image")
  
  authorId      String         @map("author_id")
  
  status        BlogPostStatus @default(DRAFT)
  viewCount     Int            @default(0) @map("view_count")
  
  publishedAt   DateTime?      @map("published_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@index([status])
  @@index([publishedAt])
  @@map("blog_posts")
}

// ============================================
// ADMIN & AUDIT
// ============================================

model AuditLog {
  id           String   @id @default(uuid())
  actorUserId  String?  @map("actor_user_id")
  action       String
  entityType   String   @map("entity_type")
  entityId     String   @map("entity_id")
  diffJson     Json?    @map("diff_json")
  createdAt    DateTime @default(now()) @map("created_at")

  actor        User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}
