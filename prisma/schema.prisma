// @ts-check

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTH
// ============================================

enum UserStatus {
  ACTIVE
  BANNED
  DELETED
}

model User {
  id               String     @id @default(uuid())
  
  // Telegram auth (for regular users and moderators)
  telegramUserId   BigInt?    @unique @map("telegram_user_id")
  telegramUsername String?    @map("telegram_username")
  phone            String?    
  
  // Admin auth (for super admin)
  username         String?    @unique
  password         String?    // bcrypt hashed
  
  displayName      String     @map("display_name")
  avatarUrl        String?    @map("avatar_url")
  isVerified       Boolean    @default(false) @map("is_verified")
  status           UserStatus @default(ACTIVE)
  
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")
  lastLoginAt      DateTime?  @map("last_login_at")

  // Relations
  listings         HorseListing[]
  favorites        Favorite[]
  reports          ReportComplaint[] @relation("Reporter")
  viewLogs         ViewLog[]
  organizedEvents  KopkariEvent[]    @relation("Organizer")
  adminRoles       AdminUserRole[]
  auditLogs        AuditLog[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("refresh_tokens")
}

// ============================================
// LOCATION
// ============================================

model Region {
  id       String     @id @default(uuid())
  nameUz   String     @map("name_uz")
  nameRu   String?    @map("name_ru")
  slug     String     @unique
  
  districts District[]
  listings  HorseListing[]
  events    KopkariEvent[]

  @@map("regions")
}

model District {
  id       String  @id @default(uuid())
  regionId String  @map("region_id")
  nameUz   String  @map("name_uz")
  nameRu   String? @map("name_ru")
  slug     String  @unique

  region   Region  @relation(fields: [regionId], references: [id], onDelete: Cascade)
  
  listings HorseListing[]
  events   KopkariEvent[]

  @@index([regionId])
  @@map("districts")
}

// ============================================
// HORSE LISTINGS
// ============================================

model Breed {
  id          String  @id @default(uuid())
  name        String  @unique
  slug        String  @unique
  description String?
  isActive    Boolean @default(true) @map("is_active")

  listings    HorseListing[]

  @@map("breeds")
}

enum HorsePurpose {
  KOPKARI
  SPORT
  SAYR
  ISHCHI
  NASLCHILIK
}

enum HorseGender {
  AYGIR    // stallion
  BIYA     // mare
  AXTa     // gelding
}

enum ListingStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  ARCHIVED
}

enum Currency {
  UZS
  USD
}

model HorseListing {
  id            String        @id @default(uuid())
  userId        String        @map("user_id")
  title         String
  slug          String        @unique
  description   String?
  
  regionId      String        @map("region_id")
  districtId    String?       @map("district_id")
  
  purpose       HorsePurpose?
  gender        HorseGender?
  breedId       String?       @map("breed_id")
  ageYears      Int?          @map("age_years")
  birthYear     Int?          @map("birth_year")
  color         String?
  height        Int?          // in cm
  weight        Int?          // in kg
  
  priceAmount   Decimal       @map("price_amount") @db.Decimal(15, 2)
  priceCurrency Currency      @default(UZS) @map("price_currency")
  
  hasPassport   Boolean       @default(false) @map("has_passport")
  hasVaccine    Boolean?      @map("has_vaccine")
  hasVideo      Boolean       @default(false) @map("has_video")
  phoneVisible  Boolean       @default(false) @map("phone_visible")
  
  status        ListingStatus @default(DRAFT)
  rejectReason  String?       @map("reject_reason")
  
  viewCount     Int           @default(0) @map("view_count")
  favoriteCount Int           @default(0) @map("favorite_count")
  
  publishedAt   DateTime?     @map("published_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  // Relations
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  region        Region        @relation(fields: [regionId], references: [id])
  district      District?     @relation(fields: [districtId], references: [id])
  breed         Breed?        @relation(fields: [breedId], references: [id])
  media         HorseMedia[]
  favorites     Favorite[]
  reports       ReportComplaint[]
  viewLogs      ViewLog[]

  @@index([userId])
  @@index([regionId])
  @@index([districtId])
  @@index([breedId])
  @@index([status])
  @@index([publishedAt])
  @@index([priceAmount])
  @@map("horse_listings")
}

enum MediaType {
  IMAGE
  VIDEO
}

model HorseMedia {
  id        String    @id @default(uuid())
  listingId String    @map("listing_id")
  type      MediaType @default(IMAGE)
  url       String
  thumbUrl  String?   @map("thumb_url")
  sortOrder Int       @default(0) @map("sort_order")
  hash      String?   // for duplicate detection
  createdAt DateTime  @default(now()) @map("created_at")

  listing   HorseListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@map("horse_media")
}

// ============================================
// USER INTERACTIONS
// ============================================

model Favorite {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  listingId String   @map("listing_id")
  createdAt DateTime @default(now()) @map("created_at")

  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   HorseListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
  @@map("favorites")
}

enum ReportTargetType {
  LISTING
  USER
  EVENT
  PRODUCT
}

enum ReportReason {
  SPAM
  FRAUD
  INAPPROPRIATE
  DUPLICATE
  WRONG_CATEGORY
  OTHER
}

enum ReportStatus {
  OPEN
  REVIEWING
  RESOLVED
  REJECTED
}

model ReportComplaint {
  id             String           @id @default(uuid())
  reporterUserId String?          @map("reporter_user_id")
  targetType     ReportTargetType @map("target_type")
  targetId       String           @map("target_id")
  reason         ReportReason
  message        String?
  status         ReportStatus     @default(OPEN)
  
  createdAt      DateTime         @default(now()) @map("created_at")
  resolvedAt     DateTime?        @map("resolved_at")

  reporter       User?            @relation("Reporter", fields: [reporterUserId], references: [id], onDelete: SetNull)
  listing        HorseListing?    @relation(fields: [targetId], references: [id], onDelete: Cascade)

  @@index([targetType, targetId])
  @@index([status])
  @@map("report_complaints")
}

model ViewLog {
  id            String   @id @default(uuid())
  listingId     String   @map("listing_id")
  userId        String?  @map("user_id")
  sessionId     String?  @map("session_id")
  ipHash        String?  @map("ip_hash")
  userAgentHash String?  @map("user_agent_hash")
  createdAt     DateTime @default(now()) @map("created_at")

  listing       HorseListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user          User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([listingId])
  @@index([userId])
  @@index([createdAt])
  @@map("view_logs")
}

// ============================================
// KOPKARI EVENTS
// ============================================

enum EventStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model KopkariEvent {
  id                  String      @id @default(uuid())
  title               String
  slug                String      @unique
  description         String?
  
  regionId            String      @map("region_id")
  districtId          String?     @map("district_id")
  addressText         String?     @map("address_text")
  mapUrl              String?     @map("map_url")
  
  startsAt            DateTime    @map("starts_at")
  endsAt              DateTime?   @map("ends_at")
  
  organizerName       String      @map("organizer_name")
  organizerUserId     String?     @map("organizer_user_id")
  isOrganizerVerified Boolean     @default(false) @map("is_organizer_verified")
  contactTelegram     String?     @map("contact_telegram")
  
  rules               String?
  prizePool           Decimal?    @map("prize_pool") @db.Decimal(15, 2)
  
  status              EventStatus @default(DRAFT)
  featured            Boolean     @default(false)
  
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  region              Region      @relation(fields: [regionId], references: [id])
  district            District?   @relation(fields: [districtId], references: [id])
  organizer           User?       @relation("Organizer", fields: [organizerUserId], references: [id], onDelete: SetNull)

  @@index([regionId])
  @@index([startsAt])
  @@index([status])
  @@map("kopkari_events")
}

// ============================================
// PRODUCTS
// ============================================

model ProductCategory {
  id       String    @id @default(uuid())
  name     String
  slug     String    @unique
  
  products Product[]

  @@map("product_categories")
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum StockStatus {
  IN_STOCK
  OUT_OF_STOCK
  PREORDER
}

model Product {
  id            String        @id @default(uuid())
  title         String
  slug          String        @unique
  categoryId    String?       @map("category_id")
  description   String?
  
  priceAmount   Decimal       @map("price_amount") @db.Decimal(15, 2)
  priceCurrency Currency      @default(UZS) @map("price_currency")
  
  hasDelivery   Boolean       @default(false) @map("has_delivery")
  stockStatus   StockStatus   @default(IN_STOCK) @map("stock_status")
  status        ProductStatus @default(DRAFT)
  
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  category      ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  media         ProductMedia[]

  @@index([categoryId])
  @@index([status])
  @@map("products")
}

model ProductMedia {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  url       String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_media")
}

// ============================================
// BLOG
// ============================================

model BlogCategory {
  id    String     @id @default(uuid())
  name  String
  slug  String     @unique
  
  posts BlogPost[]

  @@map("blog_categories")
}

model BlogTag {
  id    String        @id @default(uuid())
  name  String
  slug  String        @unique
  
  posts BlogPostTag[]

  @@map("blog_tags")
}

enum BlogStatus {
  DRAFT
  PUBLISHED
}

model BlogPost {
  id             String       @id @default(uuid())
  title          String
  slug           String       @unique
  content        String       // HTML or Markdown
  excerpt        String?
  
  categoryId     String?      @map("category_id")
  
  faqJson        Json?        @map("faq_json") // [{q: "...", a: "..."}, ...]
  
  seoTitle       String?      @map("seo_title")
  seoDescription String?      @map("seo_description")
  featuredImage  String?      @map("featured_image")
  
  status         BlogStatus   @default(DRAFT)
  publishedAt    DateTime?    @map("published_at")
  
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  category       BlogCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags           BlogPostTag[]

  @@index([categoryId])
  @@index([status])
  @@index([publishedAt])
  @@map("blog_posts")
}

model BlogPostTag {
  postId String   @map("post_id")
  tagId  String   @map("tag_id")
  
  post   BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    BlogTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@map("blog_post_tags")
}

// ============================================
// ADMIN & RBAC
// ============================================

model AdminRole {
  id          String            @id @default(uuid())
  name        String            @unique
  description String?
  
  permissions RolePermission[]
  users       AdminUserRole[]

  @@map("admin_roles")
}

model Permission {
  id          String           @id @default(uuid())
  key         String           @unique // e.g., "listings.approve", "users.ban"
  description String?
  
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  
  role         AdminRole  @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model AdminUserRole {
  userId String    @map("user_id")
  roleId String    @map("role_id")
  
  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   AdminRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("admin_user_roles")
}

model AuditLog {
  id           String   @id @default(uuid())
  actorUserId  String?  @map("actor_user_id")
  action       String   // e.g., "listing.approve", "user.ban"
  entityType   String   @map("entity_type")
  entityId     String   @map("entity_id")
  diffJson     Json?    @map("diff_json")
  ipHash       String?  @map("ip_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  actor        User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================
// BANNERS (optional)
// ============================================

enum BannerPlacement {
  HOME_TOP
  CATEGORY_SIDEBAR
  LISTING_DETAIL
}

enum BannerStatus {
  DRAFT
  ACTIVE
  EXPIRED
}

model Banner {
  id        String          @id @default(uuid())
  placement BannerPlacement
  imageUrl  String          @map("image_url")
  linkUrl   String?         @map("link_url")
  startsAt  DateTime        @map("starts_at")
  endsAt    DateTime        @map("ends_at")
  status    BannerStatus    @default(DRAFT)
  
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  @@index([placement])
  @@index([status])
  @@map("banners")
}
